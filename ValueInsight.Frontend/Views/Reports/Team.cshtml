@model ValueInsight.Frontend.Models.TeamReportViewModel
@{
    ViewData["Title"] = "Team Report";
}

<section class="container py-5 text-white">
    <div class="d-flex flex-wrap justify-content-between gap-3 align-items-start mb-4">
        <div>
            <div class="vi-badge mb-3">Team report</div>
            <h1 class="mb-2">@Model.TeamName</h1>
            <p class="text-white-50 mb-0">Team Leader: @(string.IsNullOrWhiteSpace(Model.LeaderName) ? "Not assigned" : Model.LeaderName)</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn vi-nav-cta"
               asp-controller="Reports"
               asp-action="TeamCoaching"
               asp-route-teamId="@Model.TeamId"
               asp-route-mode="quick">
                Quick team coaching
            </a>

            <a class="btn btn-outline-light"
               asp-controller="Reports"
               asp-action="TeamCoaching"
               asp-route-teamId="@Model.TeamId"
               asp-route-mode="ai">
                AI team coaching
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="vi-card-glass vi-card-glass--light p-3 h-100 text-center">
                <div class="small text-white-50">Alignment</div>
                <div class="h3 mb-0">@Model.AlignmentScore.ToString("0.0")%</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="vi-card-glass vi-card-glass--light p-3 h-100 text-center">
                <div class="small text-white-50">Culture type</div>
                <div class="h5 mb-0">@(string.IsNullOrWhiteSpace(Model.CultureType) ? "Not defined" : Model.CultureType)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="vi-card-glass vi-card-glass--light p-3 h-100 text-center">
                <div class="small text-white-50">Polarization</div>
                <div class="h3 mb-0">@Model.PolarizationScore.ToString("0.0")%</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="vi-card-glass vi-card-glass--light p-3 h-100 text-center">
                <div class="small text-white-50">Maturity index</div>
                <div class="h3 mb-0">@Model.MaturityIndex.ToString("0.0")</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
       
        <div class="col-lg-6">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                    <h2 class="h5 mb-3">Frequency of values</h2>

                    @if (Model.ValueFrequency != null && Model.ValueFrequency.Any())
                    {
                        var groupedCategories = Model.ValueFrequency
                        .GroupBy(v => v.Category)
                        .OrderByDescending(g => g.Sum(x => x.Rank))
                        .ToList();

                        <div class="accordion" id="valueFrequencyAccordion">
                            @for (int i = 0; i < groupedCategories.Count; i++)
                            {
                                var categoryGroup = groupedCategories[i];
                                var collapseId = $"collapse-category-{i}";
                                var headingId = $"heading-category-{i}";
                                var totalCount = categoryGroup.Sum(x => x.Rank);

                                <div class="accordion-item bg-transparent border-light border-opacity-10 mb-3">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button class="accordion-button collapsed bg-transparent text-white shadow-none"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#@collapseId"
                                                aria-expanded="false"
                                                aria-controls="@collapseId">
                                            <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                                <span class="fw-semibold">@categoryGroup.Key</span>
                                                <span class="text-white-50 small">Total count: @totalCount</span>
                                            </div>
                                        </button>
                                    </h2>

                                    <div id="@collapseId"
                                         class="accordion-collapse collapse"
                                         aria-labelledby="@headingId"
                                         data-bs-parent="#valueFrequencyAccordion">
                                        <div class="accordion-body pt-2">
                                            @foreach (var item in categoryGroup.OrderByDescending(x => x.Rank).ThenBy(x => x.Name))
                                            {
                                                <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 py-2">
                                                    <div>@item.Name</div>
                                                    <div class="text-white-50">@item.Rank</div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-white-50 mb-0">Value frequency is not available yet.</p>
                    }
                </div>
           
        </div>
        <div class="col-lg-6">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">Team top values</h2>
                @if (Model.TopValues.Any())
                {
                    @foreach (var item in Model.TopValues.Take(5))
                    {
                        <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 py-2">
                            <div>
                                <div class="fw-semibold">@item.Name</div>
                                <div class="small text-white-50">@item.Category</div>
                            </div>
                            <div class="text-white-50">Count: @item.Rank</div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-white-50 mb-0">Top team values are not available yet.</p>
                }
            </div>
        </div>
    </div>
        
    <div class="row g-4 mb-4">
        
        <div class="col-lg-6">
             <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                  <h2 class="h5 mb-3">Most spread values</h2>

                        @if (Model.MostSpreadValues.Any())
                        {
                            @foreach (var item in Model.MostSpreadValues)
                            {
                                <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 py-2">
                                    <div>
                                        <div class="fw-semibold">@item.Name</div>
                                        <div class="small text-white-50">@item.Category</div>
                                    </div>
                                    <div class="text-white-50">Spread: @item.SpreadScore.ToString("0.00")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-white-50 mb-0">No strongly spread values detected yet.</p>
                        }
             </div>
        </div>
        <div class="col-lg-6">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">Shared core values</h2>
                @if (Model.SharedCoreValues.Any())
                {
                    <ul class="mb-4 text-white-50">
                        @foreach (var value in Model.SharedCoreValues)
                        {
                            <li class="mb-2">@value</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-white-50">No shared values.</p>
                }
            </div>
        </div>
    </div>
    <div class="row g-4 mb-4">

        <div class="col-lg-12">
          <div class="vi-card-glass vi-card-glass--light p-4">
              <h3 class="h5 mb-3">Value Conflicts</h3>
                @if (Model.TensionFields.Any())
                {
                    <ul class="mb-0 text-white-50">
                        @foreach (var item in Model.TensionFields)
                        {
                            <li class="mb-2">@item</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-white-50 mb-0">No conflicts identified.</p>
                }
          </div>
        </div>
          
    </div>
    
           
        
