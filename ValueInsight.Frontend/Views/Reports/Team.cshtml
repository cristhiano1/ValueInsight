    <div class="row g-4 mb-4">
        <div class="col-lg-12">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">Who ranks top values?</h2>

                @if (Model.ValueOwners.Any())
                {
                    @foreach (var item in Model.ValueOwners)
                    {
                        <div class="d-flex justify-content-between border-bottom border-light border-opacity-10 py-2">

                            <div>
                                <div class="fw-semibold">@item.ValueName</div>
                                <div class="small text-white-50">@item.Category</div>
                            </div>

                            <div class="text-white-50">
                                @string.Join(", ", item.Users)
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-white-50 mb-0">No value priority data available.</p>
                }
            </div>
        </div>
    </div>
    
    <div class="row g-4 mb-4">
        <div class="col-lg-12">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">Team history</h2>
                
                @if (Model.History.Any())
                {
                    @foreach (var item in Model.History)
                    {
                        <div class="border-bottom border-light border-opacity-10 py-3">
                            <div class="d-flex flex-wrap justify-content-between gap-2 mb-2">
                                <div class="fw-semibold">@item.SnapshotDateUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                <div class="text-white-50">Coverage: @item.TeamSize member(s)</div>
                            </div>
                            <div class="text-white-50 mb-1 fs-6">Culture type: @item.CultureType</div>
                            @* <div class="small text-white-50 mb-1">Alignment: @item.AlignmentScore.ToString("0.0")% · Polarization: @item.PolarizationScore.ToString("0.0")% · Maturity: @item.MaturityIndex.ToString("0.0")</div> *@
                            @{
                                var currentIndex = Model.History.IndexOf(item);
                                var previousItem = currentIndex < Model.History.Count - 1
                                ? Model.History[currentIndex + 1]
                                : null;

                                string spreadTrend = previousItem != null
                                ? GetSpreadTrend(previousItem.PolarizationScore, item.PolarizationScore)
                                : "—";
                            }

                            <div class="text-white-50 mb-1 fs-6">
                                Alignment: @item.AlignmentScore.ToString("0.0")%
                                · Polarization: @item.PolarizationScore.ToString("0.0")%
                                · Values Spread: @GetValueSpreadLabel(item.PolarizationScore)
                                · Spread Trend: @spreadTrend
                                · Maturity: @item.MaturityIndex.ToString("0.0")
                            </div>
                            <div class="text-white-50">Top values: @string.Join(", ", item.TopValues)</div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-white-50 mb-0">No earlier team mapping is available yet.</p>
                }
            </div>
        </div>
    </div>

