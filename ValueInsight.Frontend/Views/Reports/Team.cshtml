                else
                {
                    <p class="text-white-50 mb-0">No team members yet.</p>
                }
            </div>
        </div>
    </div> *@
</section>

@functions {
    public string GetValueSpreadLabel(double polarizationScore)
    {
        if (polarizationScore >= 60)
            return "High";

        if (polarizationScore >= 30)
            return "Moderate";

        return "Low";
    }

    public string GetSpreadTrend(double previous, double current)
    {
        var diff = current - previous;

        if (Math.Abs(diff) < 2)
            return "Stable";

        if (diff > 0)
            return "Increased";

        return "Decreased";
    }
}
   
 
