                                <option value="">Select a value</option>

                                @foreach (var value in (Model?.PersonalReport?.TopValues ?? new List<ValueInsight.Frontend.Models.RankedValueViewModel>())
                                                                .OrderBy(x => x.Rank)
                                                                .Take(5))
                                {
                                    <option value="@value.Name"
                                            selected="@(string.Equals(Model?.LinkedValue, value.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                        @value.Name
                                    </option>
                                }
                            </select>
                                <div class="row g-3">
                            <label for="goalRationale" class="form-label text-white-50">
                                How does this goal connect to your value?
                            </label>

                            <textarea id="goalRationale"
                                      name="goalRationale"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Describe why this goal matters and how the value should show up in behavior.">@Model?.GoalRationale</textarea>
                        </div>
                    </div>
                    </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
