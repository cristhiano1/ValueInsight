                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="currentGoal" class="form-label text-white-50">Describe your Goal</label>
                            <textarea id="currentGoal" name="currentGoal" class="form-control" rows="4" placeholder="Example: Improve ownership and decision clarity in weekly team work.">@Model.CurrentGoal</textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="linkedValue" class="form-label text-white-50">Which top value should this goal support?</label>
                                <select id="linkedValue" name="linkedValue" class="form-select bg-dark text-white border-secondary mb-3">
                                    <option value="">Select a value</option>
