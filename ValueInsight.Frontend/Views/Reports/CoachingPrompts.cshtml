@model ValueInsight.Frontend.Models.CoachingPromptsPageViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    ViewData["Title"] = SharedLocalizer["Coach_PageTitle"];
}

<section class="container py-5 text-white">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <div class="vi-badge mb-3">@SharedLocalizer["Coach_Badge"]</div>
            <h1 class="mb-2">@SharedLocalizer["Coach_TitleFor"] @Model.PersonalReport.UserName</h1>
            <p class="text-white-50 mb-0">@SharedLocalizer["Coach_Subtitle"]</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-light" asp-action="Personal">@SharedLocalizer["Coach_BtnBack"]</a>
            <a class="btn vi-nav-cta" asp-controller="Dashboard" asp-action="Index">@SharedLocalizer["Dash_Badge"]</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">@SharedLocalizer["Coach_ContextTitle"]</h2>
                <p><strong>@SharedLocalizer["Dash_LabelTeam"]:</strong> @(Model.PersonalReport.TeamName ?? SharedLocalizer["Dash_NoTeamSelected"])</p>
                <p><strong>@SharedLocalizer["Dash_StatFit"]:</strong> @(Model.PersonalReport.CulturalFitScore?.ToString("0.0") ?? "—")</p>
                <p><strong>@SharedLocalizer["Coach_Alignment"]:</strong> @(Model.PersonalReport.AlignmentWithTeamTop5?.ToString("0.0") ?? "—")%</p>
                <p><strong>@SharedLocalizer["Dash_TopValues"]:</strong> @string.Join(", ", Model.PersonalReport.TopValues.OrderBy(x => x.Rank).Take(3).Select(x => x.Name))</p>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">@SharedLocalizer["Coach_AiPromptsTitle"]</h2>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert alert-warning mb-4">@Model.ErrorMessage</div>
                }

                @if (Model.CoachingResult != null)
                {
                    <div class="mb-4">
                        <div class="small text-white-50">@SharedLocalizer["Coach_AlignLevel"]</div>
                        <div class="h4 mb-0">@Model.CoachingResult.AlignmentLevel</div>
                    </div>

                    @if (Model.CoachingResult.Strengths.Any())
                    {
                        <div class="mb-4">
                            <h3 class="h6 text-info-emphasis">@SharedLocalizer["Coach_Strengths"]</h3>
                            <ul class="text-white-50 mb-0">
                                @foreach (var item in Model.CoachingResult.Strengths)
                                {
                                    <li class="mb-2">@item</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (Model.CoachingResult.DevelopmentAreas.Any())
                    {
                        <div class="mb-4">
                            <h3 class="h6 text-info-emphasis">@SharedLocalizer["Coach_DevAreas"]</h3>
                            <ul class="text-white-50 mb-0">
                                @foreach (var item in Model.CoachingResult.DevelopmentAreas)
                                {
                                    <li class="mb-2">@item</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (Model.CoachingResult.CoachingRecommendations.Any())
                    {
                        <div class="mb-4">
                            <h3 class="h6 text-info-emphasis">@SharedLocalizer["Coach_Actions"]</h3>
                            <ul class="text-white-50 mb-0">
                                @foreach (var item in Model.CoachingResult.CoachingRecommendations)
                                {
                                    <li class="mb-2">@item</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.CoachingResult.AICoachingAdvice))
                    {
                        <div>
                            <h3 class="h6 text-info-emphasis">@SharedLocalizer["Coach_DetailedAdvice"]</h3>
                            <div class="text-white-50" style="white-space: pre-line;">@Model.CoachingResult.AICoachingAdvice</div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-white-50 mb-0">@SharedLocalizer["Coach_NotAvailable"]</p>
                }
            </div>
        </div>

        <div class="col-12">
            <div class="vi-card-glass vi-card-glass--light p-4">
                <h2 class="h5 mb-3">@SharedLocalizer["Coach_RefPromptsTitle"]</h2>
                <ul class="mb-0 text-white-50">
                    @foreach (var item in Model.PersonalReport.CoachingQuestions)
                    {
                        <li class="mb-2">@item</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>