                                        <option value="@value.Name" selected="@(string.Equals(Model.LinkedValue, value.Name, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@value.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="row g-3">
                                <label for="goalRationale" class="form-label text-white-50">How does this goal connect to your value?</label>
                                <textarea id="goalRationale" name="goalRationale" class="form-control" rows="3" placeholder="Describe why this goal matters and how the value should show up in behavior.">@Model.GoalRationale</textarea>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn vi-nav-cta mt-3">Generate AI Coaching</button>
                </form>
            </div>
        </div>
    </div>

</section>

@functions {
    public string FormatCoachingText(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";

        var encoded = System.Net.WebUtility.HtmlEncode(text);

        
        encoded = System.Text.RegularExpressions.Regex.Replace(
            encoded,
            @"(\d+\.\s*)?([^:\n]+:)",
            "<span class=\"coach-heading\">$1$2</span>"
        );

        return encoded.Replace("\n", "<br />");
    }
}
