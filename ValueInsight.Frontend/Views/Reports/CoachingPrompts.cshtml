                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="currentGoal" class="form-label text-white-50">
                                Describe your goal
                            </label>

                            <textarea id="currentGoal"
                                      name="currentGoal"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Example: Improve ownership and decision clarity in weekly team work.">@Model?.CurrentGoal</textarea>
