                <p><strong>Team:</strong> @(Model?.PersonalReport?.TeamName ?? "No team selected")</p>
                <p><strong>Cultural fit:</strong> @(Model?.PersonalReport?.CulturalFitScore?.ToString("0.0") ?? "—")</p>
                <p><strong>Alignment with team top values:</strong> @(Model?.PersonalReport?.AlignmentWithTeamTop5?.ToString("0.0") ?? "—")%</p>
                <p><strong>Team culture:</strong> @(string.IsNullOrWhiteSpace(Model?.PersonalReport?.TeamCultureType) ? "Not available" : Model?.PersonalReport?.TeamCultureType)</p>

                <p>
                    <strong>Top values:</strong>
                    @string.Join(", ", (Model?.PersonalReport?.TopValues ?? new List<ValueInsight.Frontend.Models.RankedValueViewModel>())
