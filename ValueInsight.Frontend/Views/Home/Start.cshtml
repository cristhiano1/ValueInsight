@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    ViewData["Title"] = SharedLocalizer["Ref_PageTitle"];
}

<section class="vi-reflection">
    <div class="container pt-5 pb-0">

        <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
            <div>
                <div class="vi-badge">
                    <span class="vi-badge__dot"></span>
                    @SharedLocalizer["Ref_Step1"]
                </div>
                <h1 class="mt-3 vi-ref-title">@SharedLocalizer["Ref_Title"]</h1>
                <p class="vi-ref-subtitle">
                    @SharedLocalizer["Ref_Subtitle"]
                </p>
            </div>

            <div class="vi-save-indicator" aria-live="polite">
                <span id="viSaveDot" class="vi-save-dot"></span>
                <span id="viSaveText">@SharedLocalizer["Ref_SaveStatus_Idle"]</span>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="vi-card-glass vi-card-glass--light">
                    <h2 class="h5 fw-semibold mb-3">@SharedLocalizer["Ref_CardTitle"]</h2>

                    @for (int i = 1; i <= 4; i++)
                    {
                        <div class="vi-q mb-3">
                            <label class="vi-label" for="q@i">@SharedLocalizer[$"Ref_Q{i}"]</label>
                            <textarea id="q@i" class="form-control vi-textarea" rows="4"
                                  placeholder="@SharedLocalizer["Ref_Placeholder"]"></textarea>
                        </div>
                    }

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button id="clearBtn" class="btn btn-outline-light" type="button">
                            @SharedLocalizer["Ref_BtnClear"]
                        </button>

                        <a class="btn btn-outline-light" asp-controller="Home" asp-action="Index">
                            @SharedLocalizer["Ref_BtnHome"]
                        </a>

                        <a class="btn vi-btn-primary ms-auto" asp-controller="ValuesFlow" asp-action="SelectTen">
                            @SharedLocalizer["Ref_BtnNext"] →
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            // Texter från SharedLocalizer för användning i JS
            const uiTexts = {
                saving: "@SharedLocalizer["Ref_SaveStatus_Saving"]",
                saved: "@SharedLocalizer["Ref_SaveStatus_Saved"]",
                idle: "@SharedLocalizer["Ref_SaveStatus_Idle"]",
                confirmClear: "@SharedLocalizer["Ref_ConfirmClear"]",
                locale: "@System.Globalization.CultureInfo.CurrentCulture.Name"
            };

            const fields = [
                { id: "q1", question: "@SharedLocalizer["Ref_Q1"]" },
                { id: "q2", question: "@SharedLocalizer["Ref_Q2"]" },
                { id: "q3", question: "@SharedLocalizer["Ref_Q3"]" },
                { id: "q4", question: "@SharedLocalizer["Ref_Q4"]" }
            ];

            const saveDot = document.getElementById("viSaveDot");
            const saveText = document.getElementById("viSaveText");
            const clearBtn = document.getElementById("clearBtn");

            let saveTimer = null;

            function setSavingUI(state, timestamp) {
                saveDot.classList.remove("is-saving", "is-saved");

                if (state === "saving") {
                    saveDot.classList.add("is-saving");
                    saveText.textContent = uiTexts.saving;
                }
                else if (state === "saved") {
                    saveDot.classList.add("is-saved");
                    const t = timestamp ? new Date(timestamp) : new Date();
                    saveText.textContent = uiTexts.saved + " " + t.toLocaleTimeString(uiTexts.locale);
                }
                else {
                    saveText.textContent = uiTexts.idle;
                }
            }

            function collectPayload() {
                return {
                    answers: fields.map(f => {
                        const el = document.getElementById(f.id);
                        return {
                            questionId: f.id,
                            questionText: f.question,
                            responseText: (el?.value ?? "").trim()
                        };
                    })
                };
            }

            function restoreToForm(items) {
                if (!items || !Array.isArray(items)) return;
                items.forEach(a => {
                    const el = document.getElementById(a.questionId);
                    if (el) el.value = a.responseText ?? "";
                });
                setSavingUI("saved");
            }

            async function loadAnswers() {
                try {
                    const response = await fetch("/Reflection/Mine");
                    if (response.ok) {
                        const data = await response.json();
                        restoreToForm(data);
                    } else {
                        setSavingUI("idle");
                    }
                } catch { setSavingUI("idle"); }
            }

            async function saveAnswers() {
                const payload = collectPayload();
                try {
                    const response = await fetch("/Reflection/Save", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });
                    if (response.ok) setSavingUI("saved");
                    else setSavingUI("idle");
                } catch { setSavingUI("idle"); }
            }

            function scheduleSave() {
                setSavingUI("saving");
                if (saveTimer) clearTimeout(saveTimer);
                saveTimer = setTimeout(saveAnswers, 800);
            }

            // Bind events
            fields.forEach(f => {
                document.getElementById(f.id)?.addEventListener("input", scheduleSave);
            });

            clearBtn?.addEventListener("click", async () => {
                if (confirm(uiTexts.confirmClear)) {
                    fields.forEach(f => {
                        const el = document.getElementById(f.id);
                        if (el) el.value = "";
                    });
                    setSavingUI("saving");
                    await saveAnswers();
                }
            });

            loadAnswers();
        })();
    </script>
}