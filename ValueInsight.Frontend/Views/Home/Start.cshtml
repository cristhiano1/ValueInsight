@{
    ViewData["Title"] = "Reflection";
}

<section class="vi-reflection">
    <div class="container pt-5 pb-0">

        <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
            <div>
                <div class="vi-badge">
                    <span class="vi-badge__dot"></span>
                    Step 1 — Reflection 
                </div>
                <h1 class="mt-3 vi-ref-title">Reflection</h1>
                <p class="vi-ref-subtitle">
                    Take a few minutes to reflect. 
                </p>
            </div>

            <div class="vi-save-indicator" aria-live="polite">
                <span id="viSaveDot" class="vi-save-dot"></span>
                <span id="viSaveText">Not saved yet</span>
            </div>
        </div>

        <div class="row g-4">
            <!-- LEFT: questions -->
            <div class="col-lg-8">
                <div class="vi-card-glass vi-card-glass--light">
                    <h2 class="h5 fw-semibold mb-3">Reflection questions</h2>

                    <div class="vi-q mb-3">
                        <label class="vi-label" for="q1">1) When do you feel most proud at work?</label>
                        <textarea id="q1" class="form-control vi-textarea" rows="4"
                                  placeholder="Write freely..."></textarea>
                    </div>

                    <div class="vi-q mb-3">
                        <label class="vi-label" for="q2">2) What situations frustrate you the most?</label>
                        <textarea id="q2" class="form-control vi-textarea" rows="4"
                                  placeholder="Write freely..."></textarea>
                    </div>

                    <div class="vi-q mb-3">
                        <label class="vi-label" for="q3">3) What needs to be true for you to perform at your best?</label>
                        <textarea id="q3" class="form-control vi-textarea" rows="4"
                                  placeholder="Write freely..."></textarea>
                    </div>

                    <div class="vi-q">
                        <label class="vi-label" for="q4">4) Which behaviors do you find hard to tolerate?</label>
                        <textarea id="q4" class="form-control vi-textarea" rows="4"
                                  placeholder="Write freely..."></textarea>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button id="clearBtn" class="btn btn-outline-light" type="button">
                            Clear answers
                        </button>

                        <a class="btn btn-outline-light" asp-controller="Home" asp-action="Index">
                            Back to Home
                        </a>

                        <!-- Future step: link to next page when you build it -->
                        <button class="btn vi-btn-primary ms-auto" type="button" disabled
                                title="Next step not built yet">
                            Next →
                        </button>
                    </div>
                </div>
            </div>

                        
        </div>

    </div>
</section>

@section Scripts {
    <script>
        (() => {
          const STORAGE_KEY = "valueInsight.reflection.v1";

          const fields = [
            { id: "q1", question: "When do you feel most proud at work?" },
            { id: "q2", question: "What situations frustrate you the most?" },
            { id: "q3", question: "What needs to be true for you to perform at your best?" },
            { id: "q4", question: "Which behaviors do you find hard to tolerate?" }
          ];

          const saveDot = document.getElementById("viSaveDot");
          const saveText = document.getElementById("viSaveText");
          const clearBtn = document.getElementById("clearBtn");

          let saveTimer = null;

          function setSavingUI(state, timestamp) {
            // state: "idle" | "saving" | "saved"
            saveDot.classList.remove("is-saving", "is-saved");
            if (state === "saving") saveDot.classList.add("is-saving");
            if (state === "saved") saveDot.classList.add("is-saved");

            if (state === "saving") saveText.textContent = "Saving...";
            if (state === "idle") saveText.textContent = "Not saved yet";
            if (state === "saved") {
              const t = timestamp ? new Date(timestamp) : new Date();
              saveText.textContent = "Saved " + t.toLocaleTimeString();
            }
          }

          function readDraft() {
            try {
              const raw = localStorage.getItem(STORAGE_KEY);
              return raw ? JSON.parse(raw) : null;
            } catch {
              return null;
            }
          }

          function writeDraft(payload) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
          }

          function collectPayload() {
            const answers = fields.map(f => {
              const el = document.getElementById(f.id);
              return {
                questionId: f.id,
                questionText: f.question,
                responseText: (el?.value ?? "").trim()
              };
            });

            return {
              version: 1,
              sessionId: crypto?.randomUUID ? undefined : undefined, // optional later
              updatedAt: new Date().toISOString(),
              answers
            };
          }

          function restoreToForm(draft) {
            if (!draft || !draft.answers) return;
            for (const a of draft.answers) {
              const el = document.getElementById(a.questionId);
              if (el) el.value = a.responseText ?? "";
            }
            if (draft.updatedAt) setSavingUI("saved", draft.updatedAt);
          }

          function scheduleSave() {
            setSavingUI("saving");
            if (saveTimer) clearTimeout(saveTimer);

            // Debounce so we don't write on every keystroke instantly
            saveTimer = setTimeout(() => {
              const payload = collectPayload();
              writeDraft(payload);
              setSavingUI("saved", payload.updatedAt);
            }, 350);
          }

          function clearAll() {
            localStorage.removeItem(STORAGE_KEY);
            for (const f of fields) {
              const el = document.getElementById(f.id);
              if (el) el.value = "";
            }
            setSavingUI("idle");
          }

          // Hook up events
          for (const f of fields) {
            const el = document.getElementById(f.id);
            if (!el) continue;
            el.addEventListener("input", scheduleSave);
          }

          clearBtn?.addEventListener("click", () => {
            if (confirm("Clear all reflection answers saved in this browser?")) {
              clearAll();
            }
          });

          // Initial load
          restoreToForm(readDraft());
        })();
    </script>
}
>