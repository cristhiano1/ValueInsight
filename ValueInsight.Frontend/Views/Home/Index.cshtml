@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    ViewData["Title"] = "ValueInsight";
}

<section class="vi-hero vi-hero--premium">
    <div class="vi-hero__bg">
        <div class="vi-glow vi-glow--a"></div>
        <div class="vi-glow vi-glow--b"></div>
        <div class="vi-grid"></div>
    </div>

    <div class="container position-relative py-5">
        <div class="row align-items-center g-5">

            <div class="col-lg-6 text-white">
                <div class="vi-badge">
                    <span class="vi-badge__dot"></span>
                    @SharedLocalizer["Hero_Badge"]
                </div>

                <h1 class="vi-title mt-3">
                    @SharedLocalizer["Hero_TitleStart"]
                    <span class="vi-accent">@SharedLocalizer["Hero_TitleAccent"]</span>
                </h1>

                <p class="vi-lead mt-4">
                    @SharedLocalizer["Hero_Lead"]
                </p>

                <div class="d-flex flex-wrap align-items-center gap-3 mt-4">
                    <a class="btn vi-btn-primary btn-lg"
                       asp-controller="Account"
                       asp-action="Login">
                        @SharedLocalizer["Hero_BtnStart"]
                        <span class="vi-arrow">→</span>
                    </a>
                </div>

                <div class="vi-trusted mt-4">
                    <div class="vi-trusted-title">@SharedLocalizer["Hero_TrustedTitle"]</div>
                    <div class="vi-trusted-pills">
                        <span class="vi-trusted-pill">✨ @SharedLocalizer["Hero_Pill1"]</span>
                        <span class="vi-trusted-pill">🤝 @SharedLocalizer["Hero_Pill2"]</span>
                        <span class="vi-trusted-pill">📈 @SharedLocalizer["Hero_Pill3"]</span>
                        <span class="vi-trusted-pill">🎯 @SharedLocalizer["Hero_Pill4"]</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="vi-card-glass">
                    <div class="vi-card-glass__top">
                        <div class="vi-card-icon">🧭</div>
                        <div>
                            <div class="vi-card-title">@SharedLocalizer["Hero_CardTitle"]</div>
                            <div class="vi-card-subtitle">@SharedLocalizer["Hero_CardSubtitle"]</div>
                        </div>
                    </div>

                    <ul class="vi-checklist mt-4">
                        <li><span class="vi-check">✓</span> @SharedLocalizer["Hero_Check1"]</li>
                        <li><span class="vi-check">✓</span> @SharedLocalizer["Hero_Check2"]</li>
                        <li><span class="vi-check">✓</span> @SharedLocalizer["Hero_Check3"]</li>
                        <li><span class="vi-check">✓</span> @SharedLocalizer["Hero_Check4"]</li>
                    </ul>

                    <div class="vi-card-glass__divider"></div>

                    <div class="vi-card-note">
                        @SharedLocalizer["Hero_CardNote"]
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>