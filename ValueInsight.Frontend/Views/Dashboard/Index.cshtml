@model ValueInsight.Frontend.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var canManageWorkspace = Model.IsAdmin || Model.IsTeamLeader;
    var canOpenTeamReport = Model.TeamId.HasValue && (Model.TeamReportReady || canManageWorkspace);
    var roleLabel = Model.IsAdmin ? "Admin" : Model.IsTeamLeader ? "Team leader" : "Member";
}

<section class="container py-5 text-white">
    <div class="d-flex flex-wrap justify-content-between gap-3 align-items-start mb-4">
        <div>
            <div class="vi-badge mb-3">Dashboard</div>
            <h1 class="mb-2">Welcome, @Model.UserName</h1>
            <p class="text-white-50 mb-0">
                An overview of your profile.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn vi-nav-cta" asp-controller="Home" asp-action="Start">Start assessment</a>
            <a class="btn vi-nav-cta" asp-controller="Reports" asp-action="Personal">Personal report</a>
            @if (canOpenTeamReport)
            {
                <a class="btn vi-nav-cta" asp-controller="Reports" asp-action="Team" asp-route-teamId="@Model.TeamId">Team report</a>
            }
            else if (!Model.TeamId.HasValue)
            {
                <a class="btn vi-nav-cta" asp-controller="Teams" asp-action="Join">Join a team</a>
            }
        </div>
    </div>

    <div class="row g-5 mb-5">
        <div class="col-md-6">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="small text-white-50 mb-2">Your role</div>
                <div class="h4 mb-1">@roleLabel</div>
                <div class="small text-white-50 mb-2">Team</div>
                <div class="h4 mb-1">@(Model.TeamName ?? "No team assigned")</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="small text-white-50 mb-2">Personal report status</div>
                <div class="h4 mb-1">@(Model.AssessmentHistory.Any() ? "Available" : "Not available yet")</div>
                <div class="text-white-50">
                    @(Model.AssessmentHistory.Any()
                                        ? $"Latest assessment: {Model.AssessmentHistory.First().CompletedAtUtc.ToLocalTime():yyyy-MM-dd HH:mm}"
                                        : "Complete your first assessment to unlock your report.")
                </div>
            </div>
        </div>

    </div>

    <div class="row g-5 mb-5">
        
        <div class="col-md-6">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="small text-white-50 mb-2">Team Report status</div>
                @if (Model.TeamId.HasValue)
                {
                    <div class="h4 mb-1">@(Model.TeamReportReady ? "Available" : "Team report is in progress")</div>
                    <div class="text-white-50">
                        @if (Model.IsAdmin || Model.IsTeamLeader)
                        {
                            <span>Completion: @Model.TeamMembersCompleted / @Model.TeamMembersTotal</span>
                        }
                        else
                        {
                            <span>@(Model.CulturalFitScore.HasValue ? $"Cultural fit: {Model.CulturalFitScore.Value:0.0}" : "Team alignment not available.")</span>
                        }
                    </div>
                }
                else
                {
                    <div class="h4 mb-1">No team connected</div>
                    
                }
            </div>
        </div>

        <div class="col-lg-6">

            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                @if (canManageWorkspace)
                {
                    <h2 class="h5 mb-3">Management access</h2>
                    <p class="text-white-50">Workspace for team management.</p>
                    
                    <div class="d-grid gap-2">
                        
                        <a class="btn vi-nav-cta" asp-controller="Teams" asp-action="Workspace">Team management</a>
                    </div>
                   
                }
                else
                {
                    <h2 class="h5 mb-3">Quick access</h2>
                    <p class="text-white-50 mb-3">View your team status and Coaching prompts.</p>
                    <div class="d-grid gap-2">
                       
                        <a class="btn vi-nav-cta" asp-controller="Teams" asp-action="Workspace">View team status</a>
                        <a class="btn vi-nav-cta" asp-controller="Reports" asp-action="CoachingPrompts">Coaching prompts</a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
