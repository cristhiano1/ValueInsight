@model ValueInsight.Frontend.Models.DashboardViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    ViewData["Title"] = SharedLocalizer["Dash_PageTitle"];
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture;
}

<section class="container py-5 text-white">
    <div class="d-flex flex-wrap justify-content-between gap-3 align-items-start mb-4">
        <div>
            <div class="vi-badge mb-3">@SharedLocalizer["Dash_Badge"]</div>
            <h1 class="mb-2">@SharedLocalizer["Dash_Welcome"], @Model.UserName</h1>
            <p class="text-white-50 mb-0">@SharedLocalizer["Dash_Subtitle"]</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn vi-nav-cta" asp-controller="Home" asp-action="Start">@SharedLocalizer["Dash_BtnStart"]</a>
            <a class="btn btn-outline-light" asp-controller="Reports" asp-action="Personal">@SharedLocalizer["Dash_BtnLatestReport"]</a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="small text-white-50">@SharedLocalizer["Dash_StatAssessments"]</div>
                <div class="display-6">@Model.AssessmentsCompleted</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="small text-white-50">@SharedLocalizer["Dash_StatLatest"]</div>
                <div class="h4 mb-0">
                    @(Model.LatestAssessmentCompletedAtUtc?.ToLocalTime().ToString("g", currentCulture) ?? SharedLocalizer["Dash_NotCompleted"])
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="small text-white-50">@SharedLocalizer["Dash_StatFit"]</div>
                <div class="display-6">@(Model.CulturalFitScore?.ToString("0.0", currentCulture) ?? "—")</div>
                <div class="text-white-50">
                    @(string.IsNullOrWhiteSpace(Model.TeamCultureType) ? SharedLocalizer["Dash_NoTeamContext"] : Model.TeamCultureType)
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">@SharedLocalizer["Dash_HistoryTitle"]</h2>
                    <a class="btn btn-sm btn-outline-light" asp-controller="Home" asp-action="Start">@SharedLocalizer["Dash_BtnTakeAgain"]</a>
                </div>
                @if (Model.AssessmentHistory.Any())
                {
                    @foreach (var item in Model.AssessmentHistory)
                    {
                        <div class="border-bottom border-light border-opacity-10 py-3">
                            <div class="d-flex flex-wrap justify-content-between gap-2 mb-2">
                                <div class="fw-semibold">@item.CompletedAtUtc.ToLocalTime().ToString("g", currentCulture)</div>
                                <div class="text-white-50">@SharedLocalizer["Dash_PrimaryCat"]: @item.PrimaryCategory</div>
                            </div>
                            <div class="text-white-50">@SharedLocalizer["Dash_TopValues"]: @string.Join(", ", item.TopValues)</div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-white-50 mb-0">@SharedLocalizer["Dash_NoHistory"]</p>
                }
            </div>
        </div>
        <div class="col-lg-4">
            <div class="vi-card-glass vi-card-glass--light p-4 h-100">
                <h2 class="h5 mb-3">@SharedLocalizer["Dash_QuickAccess"]</h2>
                <p><strong>@SharedLocalizer["Dash_LabelTeam"]:</strong> @(Model.TeamName ?? SharedLocalizer["Dash_NoTeamSelected"])</p>
                <p><strong>@SharedLocalizer["Dash_LabelCulture"]:</strong> @(string.IsNullOrWhiteSpace(Model.TeamCultureType) ? SharedLocalizer["Dash_NotAvailable"] : Model.TeamCultureType)</p>
                <div class="d-grid gap-2 mt-4">
                    <a class="btn btn-outline-light" asp-controller="Reports" asp-action="Personal">@SharedLocalizer["Dash_BtnPersonalReport"]</a>

                    @if (Model.TeamId.HasValue)
                    {
                        <a class="btn btn-outline-light"
                           asp-controller="Reports"
                           asp-action="Team"
                           asp-route-teamId="@Model.TeamId">
                            @SharedLocalizer["Dash_BtnTeamReport"]
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>