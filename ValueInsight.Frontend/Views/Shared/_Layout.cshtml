@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ValueInsight</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ValueInsight.Frontend.styles.css" asp-append-version="true" />
</head>

<body class="vi-body">
    <header class="vi-header">
        <nav class="navbar navbar-expand-lg vi-navbar">
            <div class="container-fluid px-0">

                <!-- BRAND -->
                <a class="navbar-brand vi-brand" asp-controller="Home" asp-action="Index">
                    Value<span class="vi-brand-accent">Insight</span>
                </a>

                <button class="navbar-toggler vi-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#viNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- LINKS -->
                <div class="collapse navbar-collapse" id="viNav">
                    @{
                        var token = Context.Session.GetString("JWToken");
                        var role = Context.Session.GetString("Role");
                    }

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">

                        <!-- HOME -->
                        <li class="nav-item">
                            <a class="nav-link vi-navlink" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>

                        @if (string.IsNullOrEmpty(token))
                        {
                            <!-- NOT LOGGED -->
                            <li class="nav-item">
                                <a class="nav-link vi-navlink" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn vi-nav-cta" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }
                        else
                        {
                            <!-- LOGGED -->

                            <li class="nav-item">
                                <a class="nav-link vi-navlink" asp-controller="Dashboard" asp-action="Index">
                                    Dashboard
                                </a>
                            </li>

                            <!-- USER -->
                            @if (role != "Coach")
                            {
                                <li class="nav-item">
                                    <a class="nav-link vi-navlink" asp-controller="Reports" asp-action="Personal">
                                        My Report
                                    </a>
                                </li>
                            }

                            <!-- COACH -->
                            @if (role == "Coach")
                            {
                                <li class="nav-item">
                                    <a class="nav-link vi-navlink"
                                       asp-controller="Reports"
                                       asp-action="Team">
                                        Team Report
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link vi-navlink"
                                       asp-controller="Reports"
                                       asp-action="CoachingPrompts">
                                        Coaching
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="btn vi-nav-cta" asp-controller="Account" asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="vi-main">
        @RenderBody()
    </main>

    <footer class="vi-footer">
        <div class="container-fluid py-3 text-center">
            <div class="text-muted small">&copy; 2026 — ValueInsight</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>