@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ValueInsight</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ValueInsight.Frontend.styles.css" asp-append-version="true" />
</head>

<body class="vi-body">
    <header class="vi-header">
        <nav class="navbar navbar-expand-lg vi-navbar">
            <div class="container-fluid px-0">
                <a class="navbar-brand vi-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Value<span class="vi-brand-accent">Insight</span>
                </a>

                <button class="navbar-toggler vi-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#viNav"
                        aria-controls="viNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="viNav">
                    @{
                        var token = Context.Session.GetString("JWToken");
                    }

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-3">

                        <li class="nav-item d-flex align-items-center gap-2 me-lg-3">
                            <a class="nav-link vi-navlink small p-0 @(System.Globalization.CultureInfo.CurrentCulture.Name == "sv" ? "text-white fw-bold" : "text-white-50")"
                               href="?culture=sv">SV</a>
                            <span class="text-white-50 small">|</span>
                            <a class="nav-link vi-navlink small p-0 @(System.Globalization.CultureInfo.CurrentCulture.Name == "en" ? "text-white fw-bold" : "text-white-50")"
                               href="?culture=en">EN</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link vi-navlink" asp-area="" asp-controller="Home" asp-action="Index">
                                @SharedLocalizer["Nav_Home"]
                            </a>
                        </li>

                        @if (string.IsNullOrEmpty(token))
                        {
                            <li class="nav-item">
                                <a class="nav-link vi-navlink" asp-controller="Account" asp-action="Login">
                                    @SharedLocalizer["Nav_Login"]
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn vi-nav-cta" asp-controller="Account" asp-action="Register">
                                    @SharedLocalizer["Nav_Register"]
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link vi-navlink" asp-controller="Dashboard" asp-action="Index">
                                    @SharedLocalizer["Dash_Badge"]
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn vi-nav-cta" asp-controller="Account" asp-action="Logout">
                                    @SharedLocalizer["Nav_Logout"]
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="vi-main">
        @RenderBody()
    </main>

    <footer class="vi-footer border-top border-white border-opacity-10 mt-5">
        <div class="container-fluid py-4 text-center">
            <div class="text-white-50 small">
                &copy; 2026 — ValueInsight |
                <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none hover-white">
                    @SharedLocalizer["Priv_PageTitle"]
                </a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>