@if (ViewBag.SuccessMessage != null)
{
    <div class="alert alert-success mt-3">
        @ViewBag.SuccessMessage
    </div>
}
@model ValueInsight.Frontend.Models.RankTopThreeViewModel
@{
    ViewData["Title"] = "Rank Top 3";
}

<section class="container py-5">
    <div class="vi-card-glass vi-card-glass--light p-4">
        <div class="vi-badge mb-3">Step 4 — Rank</div>
        <h1 class="text-white mb-2">Rank your top 3</h1>
        <p class="text-white-50 mb-4">Choose rank 1, 2 and 3 from your selected top 5.</p>

        <form asp-action="RankTopThree" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label text-white">#1 Most important</label>
                <select asp-for="FirstValueId" class="form-select">
                    <option value="">Select value</option>
                    @foreach (var v in Model.TopFiveValues)
                    {
                        <option value="@v.Id">@v.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-white">#2</label>
                <select asp-for="SecondValueId" class="form-select">
                    <option value="">Select value</option>
                    @foreach (var v in Model.TopFiveValues)
                    {
                        <option value="@v.Id">@v.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-white">#3</label>
                <select asp-for="ThirdValueId" class="form-select">
                    <option value="">Select value</option>
                    @foreach (var v in Model.TopFiveValues)
                    {
                        <option value="@v.Id">@v.Name</option>
                    }
                </select>
            </div>

            <div class="mt-3">
                <h5 class="text-white">Your top 5 pool</h5>
                <ul class="text-white-50">
                    @foreach (var value in Model.TopFiveValues)
                    {
                        <li>@value.Name (@value.Category)</li>
                    }
                </ul>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a class="btn btn-outline-light" asp-action="ReduceToFive">Back</a>
                <button type="submit" class="btn vi-btn-primary">Save values</button>
            </div>
        </form>
    </div>
</section>