@model ValueInsight.Frontend.Models.RegisterViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    ViewData["Title"] = SharedLocalizer["Reg_Title"];
}

<div class="container mt-5" style="max-width: 500px;">
    <h2 class="mb-4">@SharedLocalizer["Reg_Title"]</h2>

    <form asp-action="Register" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="text-white"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="text-white"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="text-white"></label>
            <input asp-for="Password" class="form-control" type="password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TeamId" class="text-white"></label>
            <select asp-for="TeamId" class="form-select">
                <option value="">-- @SharedLocalizer["Reg_Optional"] --</option>
                @if (Model.Teams != null)
                {
                    foreach (var team in Model.Teams)
                    {
                        <option value="@team.Id">@team.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="TeamId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">@SharedLocalizer["Reg_BtnSubmit"]</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}